{
  "name": "kamelgt",
  "homepage": "https://kamelgt.com",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@jamiehs/zoomies": "^0.6.0",
    "fuse.js": "^6.6.2",
    "moment": "^2.29.1",
    "moment-timezone": "^0.5.34",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.49.9"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "gh-pages": "^3.2.3",
    "jsdom": "^24.0.0",
    "timezone-mock": "^1.3.4",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-svgr": "^4.2.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "start": "vite --host",
